APP_NAME=Price Tracker
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=price_tracker_db
REQUEST_TIMEOUT_SECONDS=10.0
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 Chrome/136.0 Safari/537.36

# Gmail SMTP: dung App Password, khong dung mat khau dang nhap thuong.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_google_app_password
SMTP_FROM_EMAIL=your_email@gmail.com
